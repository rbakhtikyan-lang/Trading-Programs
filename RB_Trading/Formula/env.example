# Конфигурация базы данных PostgreSQL
DB_NAME=trading_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# API ключи биржи (опционально, для публичных данных не требуется)
CEX_API_KEY=your_api_key_here
CEX_API_SECRET=your_api_secret_here

# Название биржи (по умолчанию binance)
EXCHANGE_NAME=binance

# Настройки по умолчанию
DEFAULT_TIMEFRAME=1h
DEFAULT_LIMIT=100
